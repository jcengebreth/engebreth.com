---
import Base from "../layouts/Base.astro";
---

<Base title="Projects — Jerad Engebreth" description="Open source contributions and projects">
  <div class="projects-page">

    <section>
      <h2 class="section-heading">Open Source</h2>
      <div class="project-grid">
        <article class="project-card fade-in">
          <h3>Amazon Bedrock AgentCore Samples</h3>
          <p>Contributed a CDK TypeScript sample for deploying a Knowledge Base RAG agent to Amazon Bedrock AgentCore.</p>
          <div class="tags">
            <span>CDK</span><span>TypeScript</span><span>Bedrock</span><span>RAG</span>
          </div>
          <a href="https://github.com/awslabs/amazon-bedrock-agentcore-samples/tree/main/04-infrastructure-as-code/cdk/typescript/knowledge-base-rag-agent" target="_blank" rel="noopener">View on GitHub →</a>
        </article>
      </div>
    </section>

    <section>
      <h2 class="section-heading">Personal Projects</h2>
      <div class="project-grid">
        <article class="project-card fade-in">
          <h3>engebreth.com</h3>
          <p>This website — a serverless portfolio site built with Astro, AWS CDK, S3, CloudFront, Lambda, and DynamoDB. Part of the Cloud Resume Challenge.</p>
          <div class="tags">
            <span>Astro</span><span>CDK</span><span>Lambda</span><span>DynamoDB</span><span>CloudFront</span>
          </div>
          <a href="https://github.com/jcengebreth/engebreth.com" target="_blank" rel="noopener">View on GitHub →</a>
        </article>
      </div>
    </section>

    <section>
      <h2 class="section-heading">Internal Projects</h2>
      <div class="project-grid">
        <article class="project-card project-card-wide fade-in">
          <h3>Partner Hub</h3>
          <p>Full-stack web application for managing ProServe partner relationships — tracking companies, contractors, requisitions, interviews, allocations, and projects across the hiring pipeline. Built with React (ECS Fargate), API Gateway + Lambda, DynamoDB, Cognito with Amazon Federate SSO, and CloudFront, all deployed via AWS CDK.</p>
          <p>Includes an AI assistant powered by Bedrock AgentCore Runtime with a Strands SDK agent running on Graviton, connected via WebSocket API Gateway for real-time streaming. The agent queries all DynamoDB tables through 9 tool functions for natural language partner data search and skill matching.</p>
          <div class="tags">
            <span>React</span><span>ECS</span><span>CDK</span><span>DynamoDB</span><span>Cognito</span><span>Bedrock</span><span>WebSocket</span>
          </div>
        </article>
      </div>
    </section>

    <section>
      <h2 class="section-heading">Blog Posts</h2>
      <div class="project-grid">
        <article class="project-card fade-in">
          <h3>Cloud Resume Challenge</h3>
          <p>A walkthrough of building and deploying my personal website as part of the Cloud Resume Challenge.</p>
          <a href="https://dev.to/jcengebreth/cloud-resume-challenge-c18" target="_blank" rel="noopener">Read on DEV →</a>
        </article>

        <article class="project-card fade-in">
          <h3>How I Passed the AWS Security Specialty Exam</h3>
          <p>Study tips and resources for passing the AWS Certified Security — Specialty exam.</p>
          <a href="https://dev.to/jcengebreth/how-i-passed-the-aws-certified-security-specialty-exam-am6" target="_blank" rel="noopener">Read on DEV →</a>
        </article>
      </div>
    </section>

  </div>
</Base>

<style>
  .projects-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem;
    min-height: calc(100vh - 120px);
  }

  section {
    margin-bottom: 2.25rem;
  }

  .section-heading {
    font-family: "Rokkitt", serif;
    font-size: 1.4rem;
    color: #3fb950;
    border-bottom: 2px solid rgba(63, 185, 80, 0.35);
    padding-bottom: 0.4rem;
    margin-bottom: 1.1rem;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .project-card {
    background: #161b22;
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 12px;
    padding: 1.4rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .project-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.35);
    border-color: rgba(63, 185, 80, 0.25);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.2rem;
  }

  .tags span {
    font-size: 0.72rem;
    background: rgba(63, 185, 80, 0.1);
    color: #3fb950;
    border: 1px solid rgba(63, 185, 80, 0.28);
    border-radius: 20px;
    padding: 0.2rem 0.6rem;
  }

  .project-card-wide {
    grid-column: 1 / -1;
  }

  .project-card h3 {
    font-family: "Rokkitt", serif;
    font-size: 1.15rem;
    color: #e6edf3;
  }

  .project-card p {
    color: #8b949e;
    font-size: 0.88rem;
    line-height: 1.6;
  }

  .project-card a {
    font-size: 0.85rem;
    color: #3fb950;
    margin-top: auto;
  }

  .project-card a:hover {
    color: #56d364;
  }

  @media (max-width: 600px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

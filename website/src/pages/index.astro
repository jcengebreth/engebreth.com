---
import Base from "../layouts/Base.astro";
---

<Base title="Jerad Engebreth" description="Personal website of Jerad Engebreth">
  <div class="bento-page">
    <div class="bento">

      <article class="card card-identity fade-in">
        <img src="/headshot.png" alt="Jerad Engebreth" class="headshot" />
        <h1>Jerad Engebreth</h1>
        <p class="title">Senior Security Engineer</p>
        <div class="connect">
          <a href="mailto:jerad@engebreth.com" class="btn">Email</a>
          <a href="https://www.linkedin.com/in/jerad-engebreth/" target="_blank" rel="noopener" class="btn">LinkedIn</a>
          <a href="https://github.com/jcengebreth" target="_blank" rel="noopener" class="btn">GitHub</a>
        </div>
      </article>

      <article class="card card-role fade-in">
        <span class="card-label">Current Role</span>
        <h2>Senior Security Engineer</h2>
        <p class="company">Amazon Web Services</p>
        <p class="dept">Global Professional Services · Seattle, WA</p>
        <span class="badge">Apr 2026 — Present</span>
      </article>

      <article class="card card-about fade-in">
        <p>Cloud security engineer focused on AWS security architecture, penetration testing, threat modeling, and AI/ML security controls for enterprise and government environments.</p>
      </article>

      <article class="card card-skills fade-in">
        <span class="card-label">Core Skills</span>
        <div class="tags">
          <span>Cloud Security</span>
          <span>Pen Testing</span>
          <span>Threat Modeling</span>
          <span>Zero Trust</span>
          <span>AI/ML Security</span>
          <span>IaC · CDK</span>
        </div>
      </article>

      <article class="card card-certs fade-in">
        <span class="card-label">Certifications</span>
        <ul>
          <li><strong>ISC²</strong> CISSP, CCSP</li>
          <li><strong>AWS</strong> ML Engineer, AI Practitioner</li>
          <li><strong>CompTIA</strong> Security+</li>
        </ul>
      </article>

      <article class="card card-nav fade-in">
        <a href="/resume/" class="nav-link">
          <span class="nav-arrow">→</span>
          <span>Resume</span>
        </a>
        <a href="/projects/" class="nav-link">
          <span class="nav-arrow">→</span>
          <span>Projects</span>
        </a>
      </article>

    </div>
  </div>
</Base>

<style>
  .bento-page {
    min-height: calc(100vh - 120px);
    background: #0d1117;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2.5rem 1.5rem;
  }

  .bento {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-areas:
      "identity identity role"
      "identity identity about"
      "skills   certs    nav";
    gap: 1rem;
    max-width: 900px;
    width: 100%;
  }

  .card {
    background: #161b22;
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 16px;
    padding: 1.75rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.35);
    border-color: rgba(63, 185, 80, 0.25);
  }

  .card-label {
    display: block;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #3fb950;
    margin-bottom: 0.75rem;
  }

  /* Identity */
  .card-identity {
    grid-area: identity;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 0.4rem;
    border-color: rgba(63, 185, 80, 0.2);
  }

  .headshot {
    width: 110px;
    height: 110px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid #3fb950;
    margin-bottom: 0.75rem;
  }

  .card-identity h1 {
    font-family: "Rokkitt", serif;
    font-size: 2.2rem;
    font-weight: 700;
    color: #e6edf3;
  }

  .card-identity .title {
    font-size: 1rem;
    color: #8b949e;
    margin-bottom: 1.25rem;
  }

  .connect {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
  }

  .btn {
    padding: 0.5rem 1.25rem;
    border: 2px solid #3fb950;
    border-radius: 6px;
    font-size: 0.9rem;
    color: #3fb950;
    transition: all 0.2s ease;
  }

  .btn:hover {
    background: #3fb950;
    color: #0d1117;
  }

  /* Role */
  .card-role {
    grid-area: role;
  }

  .card-role h2 {
    font-family: "Rokkitt", serif;
    font-size: 1.1rem;
    color: #e6edf3;
    margin-bottom: 0.35rem;
  }

  .card-role .company {
    font-size: 0.88rem;
    color: #3fb950;
    margin-bottom: 0.15rem;
  }

  .card-role .dept {
    font-size: 0.8rem;
    color: #6e7681;
    margin-bottom: 0.9rem;
  }

  .badge {
    display: inline-block;
    font-size: 0.72rem;
    color: #8b949e;
    background: rgba(63, 185, 80, 0.1);
    border: 1px solid rgba(63, 185, 80, 0.25);
    border-radius: 20px;
    padding: 0.2rem 0.65rem;
  }

  /* About */
  .card-about {
    grid-area: about;
  }

  .card-about p {
    font-size: 0.88rem;
    color: #8b949e;
    line-height: 1.65;
  }

  /* Skills */
  .card-skills {
    grid-area: skills;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tags span {
    font-size: 0.76rem;
    background: rgba(63, 185, 80, 0.1);
    color: #3fb950;
    border: 1px solid rgba(63, 185, 80, 0.28);
    border-radius: 20px;
    padding: 0.22rem 0.6rem;
  }

  /* Certs */
  .card-certs {
    grid-area: certs;
  }

  .card-certs ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .card-certs li {
    font-size: 0.84rem;
    color: #8b949e;
  }

  .card-certs strong {
    color: #c9d1d9;
    margin-right: 0.3rem;
  }

  /* Nav */
  .card-nav {
    grid-area: nav;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    justify-content: center;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.92rem;
    color: #8b949e;
    padding: 0.65rem 0.85rem;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.07);
    transition: all 0.2s ease;
  }

  .nav-link:hover {
    border-color: rgba(63, 185, 80, 0.5);
    color: #3fb950;
    background: rgba(63, 185, 80, 0.06);
  }

  .nav-arrow {
    color: #3fb950;
  }

  @media (max-width: 680px) {
    .bento {
      grid-template-columns: 1fr;
      grid-template-areas:
        "identity"
        "role"
        "about"
        "skills"
        "certs"
        "nav";
    }

    .card-identity h1 {
      font-size: 1.8rem;
    }
  }

  @media (min-width: 681px) and (max-width: 880px) {
    .bento {
      grid-template-columns: repeat(2, 1fr);
      grid-template-areas:
        "identity role"
        "identity about"
        "skills   certs"
        "nav      nav";
    }
  }
</style>

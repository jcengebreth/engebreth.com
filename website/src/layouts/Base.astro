---
import "@fontsource/lato/300.css";
import "@fontsource/lato/400.css";
import "@fontsource/rokkitt/400.css";
import "@fontsource/rokkitt/700.css";
import { ViewTransitions } from "astro:transitions";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Jerad Engebreth — Personal Website",
  ogImage = "/headshot.png",
} = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, "https://engebreth.com");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, "https://engebreth.com")} />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, "https://engebreth.com")} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>{title}</title>
    <ViewTransitions />
  </head>
  <body>
    <nav class="site-nav">
      <div class="nav-inner">
        <a href="/" class="nav-brand">JE</a>
        <ul class="nav-links">
          <li><a href="/" class:list={[Astro.url.pathname === "/" && "active"]}>Home</a></li>
          <li><a href="/resume/" class:list={[Astro.url.pathname === "/resume/" && "active"]}>Resume</a></li>
          <li><a href="/projects/" class:list={[Astro.url.pathname === "/projects/" && "active"]}>Projects</a></li>
        </ul>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>
        &copy; {new Date().getFullYear()} Jerad Engebreth &middot;
        <span id="visitor-count"></span>
      </p>
    </footer>

    <script>
      function animateCount(target: number, el: HTMLElement) {
        const duration = 900;
        const start = performance.now();
        const update = (now: number) => {
          const progress = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = `Visitor #${Math.floor(eased * target)}`;
          if (progress < 1) requestAnimationFrame(update);
        };
        requestAnimationFrame(update);
      }

      async function getVisitorCount() {
        try {
          const el = document.getElementById("visitor-count");
          if (!el) return;

          const cached = sessionStorage.getItem("visitor-count");
          if (cached) {
            el.textContent = `Visitor #${cached}`;
            return;
          }

          const res = await fetch(import.meta.env.PUBLIC_API_URL || "/api");
          const data = await res.json();
          sessionStorage.setItem("visitor-count", data);
          animateCount(Number(data), el);
        } catch {
          // silently fail — counter is non-critical
        }
      }

      // Re-runs on initial load and after every View Transition
      document.addEventListener("astro:page-load", () => {
        getVisitorCount();

        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("visible");
                observer.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.08 },
        );
        document.querySelectorAll(".fade-in").forEach((el) => observer.observe(el));
      });
    </script>
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    font-family: "Lato", Helvetica, Arial, sans-serif;
    font-size: 16px;
    color: #e6edf3;
    background: #0d1117;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
  }

  a {
    color: #3fb950;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  a:hover {
    color: #56d364;
  }

  /* Scroll fade-in */
  .fade-in {
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .fade-in.visible {
    opacity: 1;
    transform: none;
  }

  /* Navigation */
  .site-nav {
    background: #161b22;
    border-bottom: 2px solid #3fb950;
    padding: 0.75rem 0;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-brand {
    font-family: "Rokkitt", serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #3fb950;
  }

  .nav-links {
    list-style: none;
    display: flex;
    gap: 1.5rem;
  }

  .nav-links a {
    color: #8b949e;
    font-size: 0.95rem;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: #3fb950;
  }

  /* Footer */
  .site-footer {
    background: #161b22;
    border-top: 2px solid #3fb950;
    padding: 1rem;
    text-align: center;
    color: #8b949e;
    font-size: 0.85rem;
  }
</style>
